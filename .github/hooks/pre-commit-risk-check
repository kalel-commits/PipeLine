#!/bin/bash
# ─────────────────────────────────────────────────────────────────
# PipelineAI Pre-Commit Risk Check
# Blocks commits when predicted risk exceeds the threshold (0.7)
#
# INSTALLATION:
#   1. Copy this file to your repo's .git/hooks/pre-commit
#   2. Make it executable:  chmod +x .git/hooks/pre-commit
#   3. Ensure the PipelineAI backend is running at localhost:8000
#
# Or install for all repos globally:
#   git config --global core.hooksPath /path/to/hooks/
# ─────────────────────────────────────────────────────────────────

RISK_THRESHOLD=0.7
BACKEND_URL="http://127.0.0.1:8000/predict/latest"

echo "🤖 PipelineAI: Checking commit risk..."

# Query the backend
RESPONSE=$(curl -s -f "$BACKEND_URL" 2>/dev/null)

if [ $? -ne 0 ]; then
    echo "⚠️  PipelineAI backend not reachable. Allowing commit."
    exit 0
fi

# Parse risk and category
RISK=$(echo "$RESPONSE" | python3 -c "import sys,json; print(json.load(sys.stdin).get('risk', 0))" 2>/dev/null)
CATEGORY=$(echo "$RESPONSE" | python3 -c "import sys,json; print(json.load(sys.stdin).get('risk_category', 'Low'))" 2>/dev/null)
REASON=$(echo "$RESPONSE" | python3 -c "import sys,json; print(json.load(sys.stdin).get('reason', 'N/A'))" 2>/dev/null)

if [ -z "$RISK" ]; then
    echo "⚠️  Could not parse risk score. Allowing commit."
    exit 0
fi

# Get suggestions if available
SUGGESTIONS=$(echo "$RESPONSE" | python3 -c "
import sys, json
data = json.load(sys.stdin)
for s in data.get('suggestions', []):
    print(f\"  {s['icon']} {s['title']}: {s['detail']}\")
" 2>/dev/null)

# Check if risk exceeds threshold
BLOCKED=$(python3 -c "print('yes' if float('$RISK') > $RISK_THRESHOLD else 'no')" 2>/dev/null)

if [ "$BLOCKED" = "yes" ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║  🚫 COMMIT BLOCKED — HIGH RISK DETECTED                    ║"
    echo "╠══════════════════════════════════════════════════════════════╣"
    echo "║  Risk Score:  $(python3 -c "print(f'{float(\"$RISK\")*100:.1f}%')")                                          ║"
    echo "║  Category:    $CATEGORY                                          ║"
    echo "║  Reason:      $REASON"
    echo "╠══════════════════════════════════════════════════════════════╣"
    echo "║  💡 SUGGESTIONS:                                            ║"
    if [ -n "$SUGGESTIONS" ]; then
        echo "$SUGGESTIONS"
    fi
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo ""
    echo "To force commit anyway:  git commit --no-verify"
    exit 1
else
    echo "✅ PipelineAI: Risk is $CATEGORY ($(python3 -c "print(f'{float(\"$RISK\")*100:.1f}%')")) — Commit allowed."
    exit 0
fi
